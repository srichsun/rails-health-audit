<h1>Posts</h1>

<%# XSS: user input marked html_safe (brakeman flags this) %>
<p>Results for: <%= params[:q].html_safe %></p>

<%# Logic in the view + N+1 (each post hits user and tags per row) %>
<ul>
  <% @posts.each do |post| %>
    <li>
      <%= post.title %> —
      <% if post.user && post.user.address && post.user.address.city == "Taipei" %>
        <strong><%= post.user.name %></strong>
      <% else %>
        <%= post.user.name if post.user %>
      <% end %>
      (<%= post.tags.map(&:name).join(", ") %>)
    </li>
  <% end %>
</ul>
